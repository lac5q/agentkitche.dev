FROM node:22-bookworm-slim AS deps
WORKDIR /app/apps/kitchen
COPY apps/kitchen/package*.json ./
RUN npm ci

FROM node:22-bookworm-slim AS builder
WORKDIR /app/apps/kitchen
COPY --from=deps /app/apps/kitchen/node_modules ./node_modules
COPY apps/kitchen ./
RUN npm run build

FROM node:22-bookworm-slim AS runner
WORKDIR /app/apps/kitchen
ENV NODE_ENV=production
COPY --from=builder /app/apps/kitchen/.next ./.next
COPY --from=builder /app/apps/kitchen/public ./public
COPY --from=builder /app/apps/kitchen/package*.json ./
COPY --from=deps /app/apps/kitchen/node_modules ./node_modules
EXPOSE 3000
CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0", "--port", "3000"]
