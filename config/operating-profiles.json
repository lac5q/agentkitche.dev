{
  "defaultProfile": "local-dev",
  "profiles": {
    "local-dev": {
      "description": "Single developer machine. Loopback writes are allowed when no operator key is set.",
      "publicBaseUrl": "http://localhost:3000",
      "a2aEndpointBaseUrl": "http://localhost:3000",
      "remoteAgentNetworkPolicy": "private-network",
      "requiresHttps": false,
      "operatorAuth": "loopback-or-key"
    },
    "single-host": {
      "description": "All services run on one server or VM with explicit operator key.",
      "publicBaseUrl": "http://host.example:3000",
      "a2aEndpointBaseUrl": "http://host.example:3000",
      "remoteAgentNetworkPolicy": "private-network",
      "requiresHttps": false,
      "operatorAuth": "required-key"
    },
    "private-network": {
      "description": "Recommended startup deployment for multiple machines on Tailscale/LAN.",
      "publicBaseUrl": "http://memroos.tailnet:3000",
      "a2aEndpointBaseUrl": "http://memroos.tailnet:3000",
      "remoteAgentNetworkPolicy": "tailscale-or-lan",
      "requiresHttps": false,
      "operatorAuth": "required-key"
    },
    "cloud-https": {
      "description": "Internet-reachable deployment behind HTTPS reverse proxy or tunnel.",
      "publicBaseUrl": "https://memroos.example.com",
      "a2aEndpointBaseUrl": "https://memroos.example.com",
      "remoteAgentNetworkPolicy": "https-only",
      "requiresHttps": true,
      "operatorAuth": "required-key"
    },
    "custom": {
      "description": "Operator-supplied topology. All topology-specific values must come from environment/config.",
      "publicBaseUrl": "${MEMROOS_PUBLIC_BASE_URL}",
      "a2aEndpointBaseUrl": "${MEMROOS_A2A_ENDPOINT_BASE_URL}",
      "remoteAgentNetworkPolicy": "custom",
      "requiresHttps": null,
      "operatorAuth": "operator-defined"
    }
  },
  "requiredConfigKeys": [
    "MEMROOS_A2A_PROFILE",
    "MEMROOS_PUBLIC_BASE_URL",
    "MEMROOS_A2A_ENDPOINT_BASE_URL",
    "MEMROOS_OPERATOR_API_KEY",
    "MEM0_URL",
    "QDRANT_URL",
    "QDRANT_API_KEY",
    "NEO4J_HTTP_URL",
    "NEO4J_DATABASE",
    "NEO4J_USERNAME",
    "NEO4J_PASSWORD",
    "ORCHESTRATION_SERVICE_URL",
    "ORCHESTRATION_DB_PATH",
    "VOICE_MODE",
    "GEMINI_API_KEY"
  ]
}
