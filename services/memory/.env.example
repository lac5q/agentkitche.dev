# Mem0 Environment Variables
QDRANT_URL=https://your-qdrant-cloud-endpoint
QDRANT_API_KEY=${QDRANT_API_KEY:-your-qdrant-api-key}
OLLAMA_BASE_URL=http://localhost:11434
NEO4J_HTTP_URL=http://localhost:7474
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# Optional alert sinks used by services/memory/healthcheck.sh.
# Set at least one sink if you want launchd/cron degradation notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_KNOWLEDGE_WEBHOOK=
