{
  "name": "memroos-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/kitchen run dev --",
    "build": "npm --prefix apps/kitchen run build",
    "typecheck": "npm --prefix apps/kitchen run typecheck",
    "start": "npm --prefix apps/kitchen run start -- --port 3002",
    "start:all": "bash start.sh",
    "mcp": "bash scripts/memoroos-mcp.sh",
    "mcp:http": "bash scripts/memoroos-mcp.sh --http --host 0.0.0.0 --port ${KITCHEN_MCP_PORT:-8765}",
    "install:mcp:chatgpt": "bash scripts/install-chatgpt-mcp-launchd.sh",
    "test": "npm --prefix apps/kitchen run test --",
    "lint": "npm --prefix apps/kitchen run lint",
    "check:agents": "node scripts/check-agent-systems.mjs",
    "curate:skills": "node scripts/curate-agent-skills.mjs",
    "install:skill-curation": "node scripts/install-skill-curation-launchd.mjs",
    "profiles:check": "node scripts/validate-operating-profiles.mjs",
    "first-run:check": "node scripts/first-run-wizard.mjs --check"
  },
  "overrides": {
    "ip-address": "10.2.0",
    "postcss": "8.5.14"
  }
}
