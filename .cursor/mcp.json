{
  "mcpServers": {
    "memroos": {
      "command": "/bin/bash",
      "args": [
        "-lc",
        "export MEMROOS_ROOT=\"${MEMROOS_ROOT:-$HOME/github/memroos}\"; export KNOWLEDGE_ROOT=\"${KNOWLEDGE_ROOT:-$HOME/github/knowledge}\"; exec \"${KNOWLEDGE_PYTHON:-$HOME/github/knowledge/.venv/bin/python}\" \"$MEMROOS_ROOT/services/knowledge-mcp/knowledge_system/mcp_server.py\""
      ]
    },
    "gitnexus": {
      "command": "gitnexus",
      "args": ["mcp"]
    }
  }
}
